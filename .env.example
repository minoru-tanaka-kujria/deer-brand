# ─── Firebase Admin SDK ───
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Stripe ───
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─── Replicate (AI Art Generation) ───
REPLICATE_API_TOKEN=r8_xxx

# ─── LINE OAuth ───
LINE_CHANNEL_ID=xxxxxxxxxx
LINE_CHANNEL_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BASE_URL=https://custom.deer.gift

# ─── Admin API ───
ADMIN_SECRET_KEY=your-admin-secret
ADMIN_TOTP_SECRET=base32-totp-secret

# ─── Instagram Discount ───
IG_DISCOUNT_SECRET=your-ig-discount-hmac-secret
OPENROUTER_API_KEY=sk-or-xxx

# ─── Printful (Fulfillment) ───
PRINTFUL_API_KEY=xxx
PRINTFUL_WEBHOOK_SECRET=xxx

# ─── SendGrid (Email) ───
SENDGRID_API_KEY=SG.xxx

# ─── Monitoring (Optional) ───
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ─── CORS (Optional) ───
ALLOWED_ORIGIN=https://custom.deer.gift
