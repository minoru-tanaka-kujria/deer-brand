rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedInOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function userWritableFields() {
      return ["displayName", "photoURL", "phone", "savedAddresses", "availableCoupons"];
    }

    // ユーザーデータ: 本人のみ読取可。書込は許可フィールドのみ
    match /users/{userId} {
      allow read: if isSignedInOwner(userId);
      allow create: if isSignedInOwner(userId)
        && request.resource.data.keys().hasOnly(userWritableFields());
      allow update: if isSignedInOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(userWritableFields());
      allow delete: if false;
    }

    // アート履歴: 本人のみ読み書き可
    match /users/{userId}/arts/{artId} {
      allow read: if isSignedInOwner(userId);
      allow create: if isSignedInOwner(userId);
      allow update: if false;
      allow delete: if false;
    }

    // 注文: 本人のみ読み可、書き込みはサーバーAPIのみ（Admin SDK）
    match /orders/{orderId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.uid || request.auth.uid == resource.data.userId);
      allow write: if false; // Admin SDKのみ
    }

    // クーポン: Admin SDKのみ
    match /coupons/{code} {
      allow read: if false;
      allow write: if false;
    }

    // クーポン使用履歴: Admin SDKのみ
    match /couponUsage/{docId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.uid || request.auth.uid == resource.data.userId);
      allow write: if false;
    }

    // レビュー: ログイン必須で投稿可。approved=false 強制・rating 範囲・text 長制限。
    // 読み書き更新は Admin SDK のみ。以前は誰でも投稿可だったためボットによる大量
    // 書き込みでコストが膨らむリスクがあった。
    // NOTE: Web SDK は数値を常に double として送るため `is int` は false になる。
    //       `is number` + 1..5 の範囲チェックで同等の保護を行う。
    match /reviews/{reviewId} {
      allow create: if request.auth != null
        && request.resource.data.approved == false
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && (!("text" in request.resource.data)
            || (request.resource.data.text is string
                && request.resource.data.text.size() <= 500))
        && (!("name" in request.resource.data)
            || (request.resource.data.name is string
                && request.resource.data.name.size() <= 80));
      allow read, update, delete: if false;
    }
  }
}
